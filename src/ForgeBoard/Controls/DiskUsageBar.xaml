<UserControl
  x:Class="ForgeBoard.Controls.DiskUsageBar"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <StackPanel Spacing="8">
    <Grid Height="16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition x:Name="CacheColumn" Width="*" />
        <ColumnDefinition x:Name="ArtifactColumn" Width="*" />
        <ColumnDefinition x:Name="WorkingColumn" Width="*" />
        <ColumnDefinition x:Name="FreeColumn" Width="*" />
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0" Background="{StaticResource AccentBrush}" CornerRadius="4,0,0,4" />
      <Border Grid.Column="1" Background="{StaticResource WarningBrush}" />
      <Border Grid.Column="2" Background="{StaticResource SuccessBrush}" />
      <Border Grid.Column="3" Background="{StaticResource DividerBrush}" CornerRadius="0,4,4,0" />
    </Grid>
    <StackPanel Orientation="Horizontal" Spacing="16">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <Border Width="10" Height="10" Background="{StaticResource AccentBrush}" CornerRadius="2" />
        <TextBlock
          x:Name="CacheLabel"
          Text="Cache: 0 GB"
          FontSize="11"
          Foreground="{StaticResource MutedBrush}"
        />
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="4">
        <Border
          Width="10"
          Height="10"
          Background="{StaticResource WarningBrush}"
          CornerRadius="2"
        />
        <TextBlock
          x:Name="ArtifactLabel"
          Text="Artifacts: 0 GB"
          FontSize="11"
          Foreground="{StaticResource MutedBrush}"
        />
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="4">
        <Border
          Width="10"
          Height="10"
          Background="{StaticResource SuccessBrush}"
          CornerRadius="2"
        />
        <TextBlock
          x:Name="WorkingLabel"
          Text="Working: 0 GB"
          FontSize="11"
          Foreground="{StaticResource MutedBrush}"
        />
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="4">
        <Border
          Width="10"
          Height="10"
          Background="{StaticResource DividerBrush}"
          CornerRadius="2"
        />
        <TextBlock
          x:Name="FreeLabel"
          Text="Free: 0 GB"
          FontSize="11"
          Foreground="{StaticResource MutedBrush}"
        />
      </StackPanel>
    </StackPanel>
    <TextBlock
      x:Name="TotalLabel"
      Text="Total: 0 GB"
      FontSize="11"
      Foreground="{StaticResource HintBrush}"
    />
    <TextBlock x:Name="DriveLabel" Text="" FontSize="11" Foreground="{StaticResource HintBrush}" />
  </StackPanel>
</UserControl>
