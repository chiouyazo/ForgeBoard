<Page
  x:Class="ForgeBoard.Views.Networks.NetworksPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="{StaticResource BgBrush}"
>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="320" />
    </Grid.ColumnDefinitions>

    <!-- Left: Network definitions -->
    <Grid Grid.Column="0" Padding="24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
        <TextBlock
          Text="Networks"
          FontSize="22"
          FontWeight="Bold"
          Foreground="{StaticResource TextBrush}"
          VerticalAlignment="Center"
        />
        <Button
          Content="Add Network"
          Style="{StaticResource PrimaryButtonStyle}"
          Click="AddNetwork_Click"
        />
      </StackPanel>

      <StackPanel Grid.Row="1" Spacing="8" Margin="0,0,0,12">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock
            Text="Feed:"
            FontSize="13"
            Foreground="{StaticResource MutedBrush}"
            VerticalAlignment="Center"
          />
          <ComboBox
            ItemsSource="{Binding Feeds}"
            SelectedItem="{Binding SelectedFeed, Mode=TwoWay}"
            DisplayMemberPath="Name"
            MinWidth="200"
            FontSize="13"
          />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock
            Text="Repository:"
            FontSize="13"
            Foreground="{StaticResource MutedBrush}"
            VerticalAlignment="Center"
          />
          <ComboBox
            ItemsSource="{Binding Repositories}"
            SelectedItem="{Binding SelectedRepository, Mode=TwoWay}"
            MinWidth="200"
            FontSize="13"
          />
          <Button Content="Refresh" Click="RefreshNetworks_Click" FontSize="12" Padding="8,4" />
        </StackPanel>
      </StackPanel>

      <ListView Grid.Row="2" ItemsSource="{Binding Networks}" SelectionMode="None">
        <ListView.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="12">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock
                      Text="{Binding Name}"
                      FontSize="14"
                      FontWeight="SemiBold"
                      Foreground="{StaticResource TextBrush}"
                    />
                    <Border
                      Background="{StaticResource AccentBrush}"
                      CornerRadius="3"
                      Padding="6,2"
                    >
                      <TextBlock Text="{Binding SwitchType}" FontSize="10" Foreground="White" />
                    </Border>
                  </StackPanel>
                  <TextBlock
                    Text="{Binding Id}"
                    FontSize="11"
                    Foreground="{StaticResource HintBrush}"
                  />
                  <TextBlock
                    Text="{Binding NatSubnet}"
                    FontSize="11"
                    Foreground="{StaticResource MutedBrush}"
                  />
                </StackPanel>

                <StackPanel
                  Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="4"
                  VerticalAlignment="Center"
                >
                  <Button
                    Content="Edit"
                    Click="EditNetwork_Click"
                    Tag="{Binding Id}"
                    FontSize="11"
                    Padding="8,4"
                  />
                  <Button
                    Content="Delete"
                    Style="{StaticResource DangerButtonStyle}"
                    Click="DeleteNetwork_Click"
                    Tag="{Binding Id}"
                    FontSize="11"
                    Padding="8,4"
                  />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>
    </Grid>

    <!-- Right: Feeds panel -->
    <Border
      Grid.Column="1"
      Background="{StaticResource SurfaceBrush}"
      BorderBrush="{StaticResource BorderBrush}"
      BorderThickness="1,0,0,0"
      Padding="16"
    >
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
          Grid.Row="0"
          Text="Nexus Feeds"
          FontSize="17"
          FontWeight="SemiBold"
          Foreground="{StaticResource TextBrush}"
          Margin="0,0,0,12"
        />

        <ListView Grid.Row="1" ItemsSource="{Binding Feeds}" SelectionMode="None">
          <ListView.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource CardStyle}" Margin="0,0,0,6" Padding="10">
                <StackPanel Spacing="4">
                  <TextBlock
                    Text="{Binding Name}"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextBrush}"
                  />
                  <TextBlock
                    Text="{Binding ConnectionString}"
                    FontSize="11"
                    Foreground="{StaticResource HintBrush}"
                    TextTrimming="CharacterEllipsis"
                  />
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button
                      Content="Test"
                      Click="TestFeed_Click"
                      Tag="{Binding Id}"
                      FontSize="11"
                      Padding="8,4"
                    />
                    <Button
                      Content="Delete"
                      Style="{StaticResource DangerButtonStyle}"
                      Click="DeleteFeed_Click"
                      Tag="{Binding Id}"
                      FontSize="11"
                      Padding="8,4"
                    />
                  </StackPanel>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>

        <Button
          Grid.Row="2"
          Content="Add Feed"
          Style="{StaticResource PrimaryButtonStyle}"
          Click="AddFeed_Click"
          HorizontalAlignment="Stretch"
          Margin="0,8,0,0"
        />
      </Grid>
    </Border>
  </Grid>
</Page>
