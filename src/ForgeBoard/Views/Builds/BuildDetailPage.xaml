<Page
  x:Class="ForgeBoard.Views.Builds.BuildDetailPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:ForgeBoard.Controls"
  Background="{StaticResource BgBrush}"
>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border
      Grid.Row="0"
      Padding="24,16"
      BorderBrush="{StaticResource DividerBrush}"
      BorderThickness="0,0,0,1"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock
            Text="{Binding Title}"
            FontSize="24"
            FontWeight="Bold"
            Foreground="{StaticResource TextBrush}"
          />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <controls:StatusBadge Status="{Binding Execution.Status}" />
            <TextBlock
              Text="{Binding StatusText}"
              FontSize="13"
              Foreground="{StaticResource MutedBrush}"
              VerticalAlignment="Center"
            />
            <TextBlock
              Text="{Binding Execution.QueuedAt}"
              FontSize="11"
              Foreground="{StaticResource HintBrush}"
              VerticalAlignment="Center"
            />
          </StackPanel>

          <TextBlock
            Text="{Binding FailureDisplayMessage}"
            FontSize="13"
            Foreground="{StaticResource ErrorBrush}"
            TextWrapping="Wrap"
            Margin="0,8,0,0"
            Visibility="{Binding Execution.Status, Converter={StaticResource BuildStatusToFailedVisibilityConverter}, FallbackValue=Collapsed}"
          />
        </StackPanel>
      </Grid>
    </Border>

    <ScrollViewer x:Name="LogScrollViewer" Grid.Row="1" Margin="24,16">
      <TextBox
        x:Name="LogTextBox"
        Text="{Binding LogText}"
        IsReadOnly="True"
        AcceptsReturn="True"
        TextWrapping="NoWrap"
        FontFamily="Consolas"
        FontSize="12"
        BorderThickness="0"
      />
    </ScrollViewer>

    <Border
      Grid.Row="2"
      Background="{StaticResource SurfaceBrush}"
      BorderBrush="{StaticResource DividerBrush}"
      BorderThickness="0,1,0,0"
      Padding="24,12"
    >
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <Button
          Style="{StaticResource DangerButtonStyle}"
          Content="Cancel"
          Click="CancelBuild_Click"
          IsEnabled="{Binding CanCancel}"
          VerticalAlignment="Center"
          Padding="16,6"
        />
        <Button
          Style="{StaticResource PrimaryButtonStyle}"
          Content="Rebuild"
          Command="{Binding RebuildCommand}"
          IsEnabled="{Binding CanRebuild}"
          VerticalAlignment="Center"
          Padding="16,6"
        />
      </StackPanel>
    </Border>
  </Grid>
</Page>
