<Page
  x:Class="ForgeBoard.Views.StepLibrary.StepEditorPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="{StaticResource BgBrush}"
>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel
      Grid.Row="0"
      Spacing="16"
      Margin="24,24,24,0"
      MaxWidth="600"
      HorizontalAlignment="Left"
    >
      <TextBlock
        Text="Step Editor"
        FontSize="24"
        FontWeight="Bold"
        Foreground="{StaticResource TextBrush}"
      />

      <TextBox
        x:Name="NameBox"
        Header="Name"
        PlaceholderText="Step name"
        FontSize="13"
        AcceptsReturn="False"
        TextWrapping="NoWrap"
        HorizontalAlignment="Stretch"
      />

      <TextBox
        x:Name="DescriptionBox"
        Header="Description"
        PlaceholderText="What does this step do?"
        FontSize="13"
        AcceptsReturn="True"
        TextWrapping="Wrap"
        Height="60"
      />

      <ComboBox
        x:Name="TypeCombo"
        Header="Step Type"
        FontSize="13"
        HorizontalAlignment="Stretch"
        SelectionChanged="TypeCombo_SelectionChanged"
      >
        <ComboBoxItem Content="PowerShell" Tag="PowerShell" IsSelected="True" />
        <ComboBoxItem Content="Shell" Tag="Shell" />
        <ComboBoxItem Content="PowerShell File" Tag="PowerShellFile" />
        <ComboBoxItem Content="Shell File" Tag="ShellFile" />
        <ComboBoxItem Content="File Upload" Tag="FileUpload" />
        <ComboBoxItem Content="Windows Restart" Tag="WindowsRestart" />
        <ComboBoxItem Content="Custom" Tag="Custom" />
      </ComboBox>

      <TextBox
        x:Name="TagsBox"
        Header="Tags (comma-separated)"
        PlaceholderText="provisioning, security, network"
        FontSize="13"
        AcceptsReturn="False"
        TextWrapping="NoWrap"
        HorizontalAlignment="Stretch"
      />

      <TextBox
        x:Name="TimeoutBox"
        Header="Timeout (seconds)"
        PlaceholderText="300"
        FontSize="13"
        AcceptsReturn="False"
        TextWrapping="NoWrap"
        HorizontalAlignment="Stretch"
      />
    </StackPanel>

    <ScrollViewer Grid.Row="1" Margin="24,16,24,0">
      <StackPanel Spacing="8" MaxWidth="600" HorizontalAlignment="Left">
        <!-- PowerShell / Shell: script content -->
        <StackPanel x:Name="ScriptPanel" Spacing="4">
          <TextBlock
            Text="Script Content"
            FontSize="13"
            FontWeight="SemiBold"
            Foreground="{StaticResource MutedBrush}"
          />
          <TextBox
            x:Name="ContentBox"
            PlaceholderText="Enter script content..."
            FontFamily="Cascadia Code, Consolas, Courier New"
            FontSize="12"
            AcceptsReturn="True"
            TextWrapping="Wrap"
            MinHeight="200"
            MaxHeight="500"
            HorizontalAlignment="Stretch"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            KeyDown="ContentBox_KeyDown"
          />
        </StackPanel>

        <!-- PowerShellFile / ShellFile: file path -->
        <StackPanel x:Name="FilePathPanel" Spacing="4" Visibility="Collapsed">
          <TextBox
            x:Name="FilePathBox"
            Header="Script File Path"
            PlaceholderText="C:\scripts\setup.ps1 or /scripts/setup.sh"
            FontSize="13"
            AcceptsReturn="False"
            TextWrapping="NoWrap"
            HorizontalAlignment="Stretch"
          />
        </StackPanel>

        <!-- FileUpload: source and destination -->
        <StackPanel x:Name="FileUploadPanel" Spacing="8" Visibility="Collapsed">
          <TextBox
            x:Name="UploadSourceBox"
            Header="Source Path"
            PlaceholderText="Local file path to upload"
            FontSize="13"
            AcceptsReturn="False"
            TextWrapping="NoWrap"
            HorizontalAlignment="Stretch"
          />
          <TextBox
            x:Name="UploadDestinationBox"
            Header="Destination Path"
            PlaceholderText="Remote destination path"
            FontSize="13"
            AcceptsReturn="False"
            TextWrapping="NoWrap"
            HorizontalAlignment="Stretch"
          />
        </StackPanel>

        <!-- WindowsRestart: informational message -->
        <StackPanel x:Name="RestartPanel" Spacing="4" Visibility="Collapsed">
          <Border Style="{StaticResource CardStyle}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon
                Glyph="&#xE777;"
                FontFamily="Segoe MDL2 Assets"
                FontSize="16"
                Foreground="{StaticResource WarningBrush}"
              />
              <TextBlock
                Text="This step restarts Windows and waits for the machine to come back online."
                FontSize="13"
                Foreground="{StaticResource MutedBrush}"
                TextWrapping="Wrap"
              />
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Custom: raw HCL content -->
        <StackPanel x:Name="CustomPanel" Spacing="4" Visibility="Collapsed">
          <TextBlock
            Text="Raw HCL Content"
            FontSize="13"
            FontWeight="SemiBold"
            Foreground="{StaticResource MutedBrush}"
          />
          <TextBox
            x:Name="CustomContentBox"
            PlaceholderText="Enter raw HCL provisioner block..."
            FontFamily="Cascadia Code, Consolas, Courier New"
            FontSize="12"
            AcceptsReturn="True"
            TextWrapping="Wrap"
            MinHeight="200"
            MaxHeight="500"
            HorizontalAlignment="Stretch"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            KeyDown="ContentBox_KeyDown"
          />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <Border
      Grid.Row="2"
      Background="{StaticResource SurfaceBrush}"
      BorderBrush="{StaticResource DividerBrush}"
      BorderThickness="0,1,0,0"
      Padding="24,12"
    >
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Style="{StaticResource FilledAccentButton}" Content="Save" Click="Save_Click" />
        <Button Content="Cancel" Click="Cancel_Click" />
      </StackPanel>
    </Border>
  </Grid>
</Page>
