<Page
  x:Class="ForgeBoard.Views.Builds.BuildListPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="{StaticResource BgBrush}"
>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="24,24,24,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock
        Grid.Column="0"
        Text="Builds"
        FontSize="24"
        FontWeight="Bold"
        Foreground="{StaticResource TextBrush}"
        VerticalAlignment="Center"
      />
      <Button
        Grid.Column="1"
        Style="{StaticResource FilledAccentButton}"
        Content="New Build"
        Click="NewBuild_Click"
      />
    </Grid>

    <ListView
      Grid.Row="1"
      ItemsSource="{Binding Definitions}"
      Margin="24,16,24,24"
      SelectionMode="None"
    >
      <ListView.ItemTemplate>
        <DataTemplate>
          <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock
                  Text="{Binding Name}"
                  FontSize="14"
                  FontWeight="SemiBold"
                  Foreground="{StaticResource TextBrush}"
                />
                <TextBlock
                  Text="{Binding Description}"
                  FontSize="11"
                  Foreground="{StaticResource MutedBrush}"
                  TextTrimming="CharacterEllipsis"
                  MaxLines="1"
                />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock
                    Text="{Binding Builder}"
                    FontSize="11"
                    Foreground="{StaticResource HintBrush}"
                  />
                  <TextBlock
                    Text="{Binding CreatedAt}"
                    FontSize="11"
                    Foreground="{StaticResource HintBrush}"
                  />
                </StackPanel>
              </StackPanel>
              <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="4"
                VerticalAlignment="Center"
              >
                <Button
                  Style="{StaticResource PrimaryButtonStyle}"
                  Content="Run"
                  Click="RunBuild_Click"
                  Tag="{Binding Id}"
                />
                <Button Content="Edit" Click="EditBuild_Click" Tag="{Binding Id}" />
                <Button Content="Clone" Click="CloneBuild_Click" Tag="{Binding Id}" />
                <Button
                  Style="{StaticResource DangerButtonStyle}"
                  Content="Delete"
                  Click="DeleteBuild_Click"
                  Tag="{Binding Id}"
                />
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>
  </Grid>
</Page>
