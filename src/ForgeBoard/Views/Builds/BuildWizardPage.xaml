<Page
  x:Class="ForgeBoard.Views.Builds.BuildWizardPage"
  x:Name="WizardRoot"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:ForgeBoard.Controls"
  Background="{StaticResource BgBrush}"
>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock
      Grid.Row="0"
      Text="{Binding PageTitle}"
      FontSize="24"
      FontWeight="Bold"
      Foreground="{StaticResource TextBrush}"
      Margin="24,24,24,16"
    />

    <controls:WizardStepper
      Grid.Row="1"
      x:Name="Stepper"
      CurrentStep="{Binding CurrentStep}"
      Margin="24,0,24,16"
    />

    <ScrollViewer Grid.Row="2" Padding="24,0">
      <Grid>
        <!-- Step 0: Base Image -->
        <StackPanel
          x:Name="Step0Panel"
          Spacing="12"
          Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=0}"
        >
          <TextBlock
            Text="Select Base Image"
            FontSize="17"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextBrush}"
          />
          <TextBox
            PlaceholderText="Search images..."
            Text="{Binding ImageSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            FontSize="13"
            Margin="0,0,0,8"
            AcceptsReturn="False"
            TextWrapping="NoWrap"
            MaxWidth="400"
            HorizontalAlignment="Left"
          />
          <GridView
            ItemsSource="{Binding FilteredBaseImages}"
            SelectedItem="{Binding SelectedBaseImage, Mode=TwoWay}"
            SelectionMode="Single"
          >
            <GridView.ItemTemplate>
              <DataTemplate>
                <Border Style="{StaticResource CardStyle}" Width="220" Margin="4">
                  <StackPanel Spacing="4">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock
                        Grid.Column="0"
                        Text="{Binding Name}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextBrush}"
                      />
                      <Border
                        Grid.Column="1"
                        CornerRadius="3"
                        Padding="6,2"
                        Background="{StaticResource AccentBrush}"
                      >
                        <TextBlock
                          Text="{Binding Format}"
                          FontSize="9"
                          Foreground="White"
                          FontWeight="Bold"
                        />
                      </Border>
                    </Grid>
                    <TextBlock
                      Text="{Binding FileName}"
                      FontSize="11"
                      Foreground="{StaticResource MutedBrush}"
                      TextTrimming="CharacterEllipsis"
                    />
                    <TextBlock
                      Text="{Binding Description}"
                      FontSize="11"
                      Foreground="{StaticResource HintBrush}"
                      MaxLines="2"
                      TextTrimming="CharacterEllipsis"
                    />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock
                        FontSize="11"
                        Foreground="{StaticResource HintBrush}"
                        Text="{Binding FileSizeBytes, Converter={StaticResource FileSizeConverter}}"
                      />
                      <Border
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="3"
                        Padding="4,1"
                      >
                        <TextBlock
                          Text="{Binding Origin}"
                          FontSize="9"
                          Foreground="{StaticResource HintBrush}"
                        />
                      </Border>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </GridView.ItemTemplate>
          </GridView>

          <StackPanel
            Spacing="8"
            Visibility="{Binding IsIsoBaseImage, Converter={StaticResource BoolToVisibilityConverter}}"
          >
            <TextBlock
              Text="Autounattend.xml (optional)"
              FontSize="13"
              FontWeight="SemiBold"
              Foreground="{StaticResource TextBrush}"
            />
            <TextBlock
              Text="Path to an Autounattend.xml file on the build host. Packer attaches it as a floppy disk so Windows Setup runs unattended."
              FontSize="12"
              TextWrapping="Wrap"
              Foreground="{StaticResource MutedBrush}"
            />
            <TextBox
              Text="{Binding UnattendPath, Mode=TwoWay}"
              PlaceholderText="C:\path\to\Autounattend.xml"
              FontSize="12"
            />
          </StackPanel>
        </StackPanel>

        <!-- Step 1: Build Steps -->
        <StackPanel
          x:Name="Step1Panel"
          Spacing="12"
          Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=1}"
        >
          <TextBlock
            Text="Build Steps"
            FontSize="17"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextBrush}"
          />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="16" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="8">
              <TextBlock
                Text="Step Library"
                FontSize="13"
                FontWeight="SemiBold"
                Foreground="{StaticResource MutedBrush}"
              />
              <TextBox
                PlaceholderText="Search steps..."
                Text="{Binding StepSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                FontSize="13"
                AcceptsReturn="False"
                TextWrapping="NoWrap"
                HorizontalAlignment="Stretch"
              />
              <ListView ItemsSource="{Binding FilteredAvailableSteps}" SelectionMode="None">
                <ListView.ItemTemplate>
                  <DataTemplate>
                    <Border Style="{StaticResource CardStyle}" Padding="8" Margin="0,0,0,4">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                          <TextBlock
                            Text="{Binding Name}"
                            FontSize="13"
                            Foreground="{StaticResource TextBrush}"
                          />
                          <TextBlock
                            Text="{Binding Description}"
                            FontSize="11"
                            Foreground="{StaticResource HintBrush}"
                            MaxLines="1"
                            TextTrimming="CharacterEllipsis"
                          />
                        </StackPanel>
                        <Button
                          Grid.Column="1"
                          Content="&#xE710;"
                          FontFamily="Segoe MDL2 Assets"
                          Click="AddStepFromLibrary_Click"
                          Tag="{Binding Id}"
                          VerticalAlignment="Center"
                        />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </StackPanel>

            <StackPanel Grid.Column="2" Spacing="8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                  Grid.Column="0"
                  Text="Build Pipeline"
                  FontSize="13"
                  FontWeight="SemiBold"
                  Foreground="{StaticResource MutedBrush}"
                  VerticalAlignment="Center"
                />
                <Button
                  Grid.Column="1"
                  Content="Add Inline Script"
                  Style="{StaticResource PrimaryButtonStyle}"
                  Command="{Binding AddCustomStepCommand}"
                />
              </Grid>
              <TextBlock
                Text="Packer Steps"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{StaticResource AccentBrush}"
                Margin="0,4,0,2"
                Visibility="{Binding HasPackerSteps, Converter={StaticResource BoolToVisibilityConverter}}"
              />
              <ListView
                ItemsSource="{Binding PackerSteps}"
                SelectionMode="None"
                Visibility="{Binding HasPackerSteps, Converter={StaticResource BoolToVisibilityConverter}}"
              >
                <ListView.ItemTemplate>
                  <DataTemplate>
                    <StackPanel>
                      <Border Style="{StaticResource CardStyle}" Padding="8" Margin="0,0,0,4">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,4,0">
                            <Button
                              Content="&#xE70E;"
                              FontFamily="Segoe MDL2 Assets"
                              FontSize="10"
                              Padding="4,2"
                              MinWidth="0"
                              MinHeight="0"
                              Click="MoveStepUp_Click"
                              Tag="{Binding Id}"
                            />
                            <Button
                              Content="&#xE70D;"
                              FontFamily="Segoe MDL2 Assets"
                              FontSize="10"
                              Padding="4,2"
                              MinWidth="0"
                              MinHeight="0"
                              Click="MoveStepDown_Click"
                              Tag="{Binding Id}"
                            />
                          </StackPanel>
                          <TextBlock
                            Grid.Column="1"
                            Text="{Binding Order}"
                            FontSize="13"
                            FontWeight="Bold"
                            Foreground="{StaticResource AccentBrush}"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                          />
                          <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock
                              Text="{Binding Name}"
                              FontSize="13"
                              Foreground="{StaticResource TextBrush}"
                            />
                            <TextBlock
                              Text="{Binding StepType}"
                              FontSize="11"
                              Foreground="{StaticResource HintBrush}"
                            />
                          </StackPanel>
                          <Button
                            Grid.Column="3"
                            Content="&#xE78C;"
                            FontFamily="Segoe MDL2 Assets"
                            Click="SaveStepToLibrary_Click"
                            Tag="{Binding Id}"
                            ToolTipService.ToolTip="Save to Library"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                          />
                          <Button
                            Grid.Column="4"
                            Content="&#xE70F;"
                            FontFamily="Segoe MDL2 Assets"
                            Click="ToggleStepEdit_Click"
                            Tag="{Binding Id}"
                            ToolTipService.ToolTip="Edit"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                          />
                          <Button
                            Grid.Column="5"
                            Content="&#xE74D;"
                            FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="RemoveStep_Click"
                            Tag="{Binding Id}"
                            ToolTipService.ToolTip="Remove"
                          />
                        </Grid>
                      </Border>
                    </StackPanel>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>

              <TextBlock
                Text="Direct Steps"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{StaticResource MutedBrush}"
                Margin="0,8,0,2"
                Visibility="{Binding HasDirectSteps, Converter={StaticResource BoolToVisibilityConverter}}"
              />
              <ListView
                ItemsSource="{Binding DirectSteps}"
                SelectionMode="None"
                Visibility="{Binding HasDirectSteps, Converter={StaticResource BoolToVisibilityConverter}}"
              >
                <ListView.ItemTemplate>
                  <DataTemplate>
                    <StackPanel>
                      <Border Style="{StaticResource CardStyle}" Padding="8" Margin="0,0,0,4">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,4,0">
                            <Button
                              Content="&#xE70E;"
                              FontFamily="Segoe MDL2 Assets"
                              FontSize="10"
                              Padding="4,2"
                              MinWidth="0"
                              MinHeight="0"
                              Click="MoveStepUp_Click"
                              Tag="{Binding Id}"
                            />
                            <Button
                              Content="&#xE70D;"
                              FontFamily="Segoe MDL2 Assets"
                              FontSize="10"
                              Padding="4,2"
                              MinWidth="0"
                              MinHeight="0"
                              Click="MoveStepDown_Click"
                              Tag="{Binding Id}"
                            />
                          </StackPanel>
                          <TextBlock
                            Grid.Column="1"
                            Text="{Binding Order}"
                            FontSize="13"
                            FontWeight="Bold"
                            Foreground="{StaticResource AccentBrush}"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                          />
                          <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock
                              Text="{Binding Name}"
                              FontSize="13"
                              Foreground="{StaticResource TextBrush}"
                            />
                            <TextBlock
                              Text="{Binding StepType}"
                              FontSize="11"
                              Foreground="{StaticResource HintBrush}"
                            />
                          </StackPanel>
                          <Button
                            Grid.Column="3"
                            Content="&#xE78C;"
                            FontFamily="Segoe MDL2 Assets"
                            Click="SaveStepToLibrary_Click"
                            Tag="{Binding Id}"
                            ToolTipService.ToolTip="Save to Library"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                          />
                          <Button
                            Grid.Column="4"
                            Content="&#xE70F;"
                            FontFamily="Segoe MDL2 Assets"
                            Click="ToggleStepEdit_Click"
                            Tag="{Binding Id}"
                            ToolTipService.ToolTip="Edit"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                          />
                          <Button
                            Grid.Column="5"
                            Content="&#xE74D;"
                            FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="RemoveStep_Click"
                            Tag="{Binding Id}"
                            ToolTipService.ToolTip="Remove"
                          />
                        </Grid>
                      </Border>
                    </StackPanel>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>

              <!-- Inline Step Editor -->
              <Border
                Style="{StaticResource CardStyle}"
                Padding="12"
                Visibility="{Binding SelectedStepForEdit, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}"
              >
                <StackPanel Spacing="8">
                  <TextBlock
                    Text="Edit Step"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextBrush}"
                  />
                  <TextBox
                    Header="Name"
                    Text="{Binding SelectedStepForEdit.Name, Mode=TwoWay}"
                    FontSize="12"
                    AcceptsReturn="False"
                    TextWrapping="NoWrap"
                    HorizontalAlignment="Stretch"
                  />
                  <TextBox
                    Header="Content"
                    AcceptsReturn="True"
                    Text="{Binding SelectedStepForEdit.Content, Mode=TwoWay}"
                    MaxHeight="200"
                    FontFamily="Consolas"
                    FontSize="12"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Stretch"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                  />
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                      Grid.Column="0"
                      Text="{Binding SelectedStepForEdit.StepType}"
                      FontSize="11"
                      Foreground="{StaticResource HintBrush}"
                      VerticalAlignment="Center"
                    />
                    <CheckBox
                      Grid.Column="1"
                      Content="Run via Packer"
                      IsChecked="{Binding SelectedStepForEdit.UsePacker, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Margin="8,0"
                    />
                    <TextBox
                      Grid.Column="2"
                      Header="Timeout (sec)"
                      Text="{Binding SelectedStepForEdit.TimeoutSeconds, Mode=TwoWay}"
                      FontSize="12"
                      AcceptsReturn="False"
                      TextWrapping="NoWrap"
                      HorizontalAlignment="Stretch"
                    />
                  </Grid>
                  <Button
                    Content="Done"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="CloseStepEdit_Click"
                  />
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </StackPanel>

        <!-- Step 2: Configuration -->
        <StackPanel
          x:Name="Step2Panel"
          Spacing="12"
          Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=2}"
        >
          <TextBlock
            Text="Output Configuration"
            FontSize="17"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextBrush}"
          />
          <Grid MaxWidth="500" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
              <TextBox
                Header="Output Name"
                Text="{Binding OutputName, Mode=TwoWay}"
                PlaceholderText="my-image-v1"
                FontSize="13"
                AcceptsReturn="False"
                TextWrapping="NoWrap"
                HorizontalAlignment="Stretch"
              />
              <TextBox
                Header="Description"
                Text="{Binding Description, Mode=TwoWay}"
                PlaceholderText="Describe this build"
                FontSize="13"
                AcceptsReturn="False"
                TextWrapping="NoWrap"
                HorizontalAlignment="Stretch"
              />
              <TextBox
                Header="Version"
                Text="{Binding Version, Mode=TwoWay}"
                PlaceholderText="1.0"
                FontSize="13"
                AcceptsReturn="False"
                TextWrapping="NoWrap"
                HorizontalAlignment="Stretch"
              />
              <ComboBox
                Header="Builder"
                ItemsSource="{Binding AvailableBuilders}"
                SelectedItem="{Binding Builder, Mode=TwoWay}"
                FontSize="13"
              />
              <ComboBox
                Header="Output Format"
                ItemsSource="{Binding AvailableOutputFormats}"
                SelectedItem="{Binding OutputFormat, Mode=TwoWay}"
                FontSize="13"
              />
              <StackPanel Spacing="4">
                <TextBlock Text="Memory" FontSize="13" Foreground="{StaticResource MutedBrush}" />
                <Slider
                  Minimum="1024"
                  Maximum="32768"
                  StepFrequency="1024"
                  Value="{Binding MemoryMb, Mode=TwoWay}"
                />
                <TextBlock FontSize="11" Foreground="{StaticResource HintBrush}">
                  <Run Text="{Binding MemoryMb}" />
                  <Run Text=" MB" />
                </TextBlock>
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock
                  Text="CPU Count"
                  FontSize="13"
                  Foreground="{StaticResource MutedBrush}"
                />
                <Slider
                  Minimum="1"
                  Maximum="16"
                  StepFrequency="1"
                  Value="{Binding CpuCount, Mode=TwoWay}"
                />
                <TextBlock FontSize="11" Foreground="{StaticResource HintBrush}">
                  <Run Text="{Binding CpuCount}" />
                  <Run Text=" cores" />
                </TextBlock>
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock
                  Text="Disk Size"
                  FontSize="13"
                  Foreground="{StaticResource MutedBrush}"
                />
                <Slider
                  Minimum="10"
                  Maximum="500"
                  StepFrequency="10"
                  Value="{Binding DiskSizeGb, Mode=TwoWay}"
                />
                <TextBlock FontSize="11" Foreground="{StaticResource HintBrush}">
                  <Run Text="{Binding DiskSizeGb}" />
                  <Run Text=" GB" />
                </TextBlock>
              </StackPanel>
              <TextBox
                Header="Tags (comma-separated)"
                Text="{Binding Tags, Mode=TwoWay}"
                PlaceholderText="windows, server, 2022"
                FontSize="13"
                AcceptsReturn="False"
                TextWrapping="NoWrap"
                HorizontalAlignment="Stretch"
              />
              <TextBox
                Header="Post-Processors (comma-separated)"
                Text="{Binding PostProcessors, Mode=TwoWay}"
                PlaceholderText="compress, checksum"
                FontSize="13"
                AcceptsReturn="False"
                TextWrapping="NoWrap"
                HorizontalAlignment="Stretch"
              />
            </StackPanel>
          </Grid>
        </StackPanel>

        <!-- Step 3: Review & Preview -->
        <StackPanel
          x:Name="Step3Panel"
          Spacing="12"
          Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=3}"
        >
          <TextBlock
            Text="Review and Preview"
            FontSize="17"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextBrush}"
          />
          <Border Style="{StaticResource CardStyle}">
            <StackPanel Spacing="8">
              <TextBlock FontSize="13" Foreground="{StaticResource TextBrush}">
                <Run Text="Name: " FontWeight="SemiBold" />
                <Run Text="{Binding OutputName}" />
              </TextBlock>
              <TextBlock FontSize="13" Foreground="{StaticResource TextBrush}">
                <Run Text="Base Image: " FontWeight="SemiBold" />
                <Run Text="{Binding SelectedBaseImage.Name}" />
              </TextBlock>
              <TextBlock FontSize="13" Foreground="{StaticResource TextBrush}">
                <Run Text="Builder: " FontWeight="SemiBold" />
                <Run Text="{Binding Builder}" />
              </TextBlock>
              <TextBlock FontSize="13" Foreground="{StaticResource TextBrush}">
                <Run Text="Steps: " FontWeight="SemiBold" />
                <Run Text="{Binding BuildSteps.Count}" />
              </TextBlock>
              <TextBlock FontSize="13" Foreground="{StaticResource TextBrush}">
                <Run Text="Memory: " FontWeight="SemiBold" />
                <Run Text="{Binding MemoryMb}" />
                <Run Text=" MB" />
              </TextBlock>
              <TextBlock FontSize="13" Foreground="{StaticResource TextBrush}">
                <Run Text="CPUs: " FontWeight="SemiBold" />
                <Run Text="{Binding CpuCount}" />
                <Run Text=" cores" />
              </TextBlock>
              <TextBlock FontSize="13" Foreground="{StaticResource TextBrush}">
                <Run Text="Disk: " FontWeight="SemiBold" />
                <Run Text="{Binding DiskSizeGb}" />
                <Run Text=" GB" />
              </TextBlock>
              <TextBlock FontSize="13" Foreground="{StaticResource TextBrush}">
                <Run Text="Format: " FontWeight="SemiBold" />
                <Run Text="{Binding OutputFormat}" />
              </TextBlock>
              <TextBlock FontSize="13" Foreground="{StaticResource TextBrush}">
                <Run Text="Tags: " FontWeight="SemiBold" />
                <Run Text="{Binding Tags}" />
              </TextBlock>
            </StackPanel>
          </Border>

          <TextBlock
            Text="{Binding ValidationMessage}"
            FontSize="13"
            Foreground="{StaticResource WarningBrush}"
          />

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button
              Style="{StaticResource PrimaryButtonStyle}"
              Content="Validate"
              Command="{Binding ValidateCommand}"
            />
            <Button Content="Preview Build" Command="{Binding PreviewCommand}" />
          </StackPanel>
        </StackPanel>
      </Grid>
    </ScrollViewer>

    <Border
      Grid.Row="3"
      Background="{StaticResource SurfaceBrush}"
      BorderBrush="{StaticResource DividerBrush}"
      BorderThickness="0,1,0,0"
      Padding="24,12"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Button
          Grid.Column="0"
          Content="Back"
          Command="{Binding BackCommand}"
          Visibility="{Binding IsFirstStep, Converter={StaticResource BoolToInverseVisibilityConverter}}"
        />
        <TextBlock
          Grid.Column="1"
          Text="{Binding ValidationMessage}"
          FontSize="13"
          Foreground="{StaticResource WarningBrush}"
          VerticalAlignment="Center"
          Margin="16,0"
          TextWrapping="Wrap"
        />
        <Button
          Grid.Column="2"
          Content="Save Draft"
          Command="{Binding SaveDraftCommand}"
          Visibility="{Binding IsLastStep, Converter={StaticResource BoolToVisibilityConverter}}"
          Margin="0,0,8,0"
        />
        <Button
          Grid.Column="3"
          Style="{StaticResource PrimaryButtonStyle}"
          Content="{Binding NextButtonText}"
          Command="{Binding NextCommand}"
        />
      </Grid>
    </Border>
  </Grid>
</Page>
