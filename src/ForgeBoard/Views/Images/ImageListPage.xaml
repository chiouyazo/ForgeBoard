<Page
  x:Class="ForgeBoard.Views.Images.ImageListPage"
  x:Name="ImageLibraryRoot"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:ForgeBoard.Controls"
  Background="{StaticResource BgBrush}"
>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="320" />
    </Grid.ColumnDefinitions>

    <Grid Grid.Column="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Notification Bar -->
      <Border
        x:Name="NotificationBar"
        Grid.Row="0"
        Background="{StaticResource WarningBrush}"
        Padding="16,8"
        Visibility="Collapsed"
      >
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock
            x:Name="NotificationText"
            Grid.Column="0"
            FontSize="13"
            Foreground="White"
            VerticalAlignment="Center"
          />
          <Button
            Grid.Column="1"
            Content="&#xE711;"
            FontFamily="Segoe MDL2 Assets"
            Click="DismissNotification_Click"
            Foreground="White"
            Background="Transparent"
            BorderThickness="0"
          />
        </Grid>
      </Border>

      <!-- Header -->
      <Grid Grid.Row="1" Margin="24,24,24,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock
          Grid.Column="0"
          Text="Image Library"
          FontSize="24"
          FontWeight="Bold"
          Foreground="{StaticResource TextBrush}"
          VerticalAlignment="Center"
        />
        <Button
          Grid.Column="1"
          Style="{StaticResource FilledAccentButton}"
          Content="Add Local Image"
          Click="AddLocalImage_Click"
          Margin="0,0,8,0"
        />
        <Button
          Grid.Column="2"
          Style="{StaticResource PrimaryButtonStyle}"
          Content="Import from Feed"
          Click="ImportFromFeed_Click"
        />
      </Grid>

      <!-- Disk Usage -->
      <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="24,16,24,0">
        <controls:DiskUsageBar DiskUsage="{Binding DiskUsage}" />
      </Border>

      <!-- Filter Bar -->
      <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="24,12,24,0" Padding="12">
        <StackPanel Orientation="Horizontal" Spacing="12">
          <TextBox
            PlaceholderText="Search images..."
            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Width="250"
            FontSize="13"
            AcceptsReturn="False"
            TextWrapping="NoWrap"
            Padding="8,4"
            Height="32"
            VerticalAlignment="Center"
          />
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock
              Text="Type:"
              FontSize="13"
              Foreground="{StaticResource MutedBrush}"
              VerticalAlignment="Center"
            />
            <ComboBox
              ItemsSource="{Binding TypeFilterOptions}"
              SelectedItem="{Binding SelectedTypeFilter, Mode=TwoWay}"
              FontSize="13"
              Width="130"
            />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock
              Text="Origin:"
              FontSize="13"
              Foreground="{StaticResource MutedBrush}"
              VerticalAlignment="Center"
            />
            <ComboBox
              ItemsSource="{Binding OriginFilterOptions}"
              SelectedItem="{Binding SelectedOriginFilter, Mode=TwoWay}"
              FontSize="13"
              Width="130"
            />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Add Local Image Panel -->
      <Border
        x:Name="LocalImagePanel"
        Grid.Row="4"
        Style="{StaticResource CardStyle}"
        Margin="24,12,24,0"
        Visibility="Collapsed"
      >
        <StackPanel Spacing="8">
          <TextBlock
            Text="Add Local Image"
            FontSize="15"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextBrush}"
          />
          <TextBlock
            Text="Point directly to a local .box, .iso, .vhdx, or .qcow2 file to use as a base image."
            FontSize="11"
            Foreground="{StaticResource MutedBrush}"
            TextWrapping="Wrap"
          />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
              x:Name="LocalPathBox"
              Grid.Column="0"
              Header="File Path"
              Text="{Binding LocalImagePath, Mode=TwoWay}"
              PlaceholderText="C:\images\base-win11.box"
              FontSize="13"
              AcceptsReturn="False"
              TextWrapping="NoWrap"
              HorizontalAlignment="Stretch"
              TextChanged="LocalPathBox_TextChanged"
            />
            <Button
              Grid.Column="1"
              Content="Browse"
              Click="BrowseLocalImage_Click"
              VerticalAlignment="Bottom"
              Margin="8,0,0,0"
            />
          </Grid>
          <TextBox
            x:Name="LocalNameBox"
            Header="Image Name (optional)"
            Text="{Binding LocalImageName, Mode=TwoWay}"
            PlaceholderText="Friendly name for this image"
            FontSize="13"
            AcceptsReturn="False"
            TextWrapping="NoWrap"
            HorizontalAlignment="Stretch"
          />
          <TextBlock x:Name="FileSizeText" FontSize="11" Foreground="{StaticResource HintBrush}" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button
              Style="{StaticResource PrimaryButtonStyle}"
              Content="Add"
              Command="{Binding AddLocalImageCommand}"
            />
            <Button Content="Cancel" Click="CancelLocalImage_Click" />
          </StackPanel>
          <TextBlock
            Text="{Binding ErrorMessage}"
            FontSize="13"
            Foreground="{StaticResource ErrorBrush}"
            TextWrapping="Wrap"
          />
        </StackPanel>
      </Border>

      <!-- Image List -->
      <ListView
        Grid.Row="5"
        ItemsSource="{Binding FilteredImages}"
        Margin="24,16,24,24"
        SelectionMode="None"
      >
        <ListView.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Format Badge -->
                <Border
                  Grid.Column="0"
                  CornerRadius="4"
                  Padding="8,4"
                  VerticalAlignment="Center"
                  Margin="0,0,12,0"
                  Background="{Binding Format, Converter={StaticResource FormatColorConverter}, FallbackValue=#9C27B0}"
                >
                  <TextBlock
                    Text="{Binding Format}"
                    FontSize="11"
                    FontWeight="Bold"
                    Foreground="White"
                    CharacterSpacing="60"
                  />
                </Border>

                <!-- Center: name, description, date, cache -->
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock
                    Text="{Binding Name}"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="{StaticResource TextBrush}"
                  />
                  <TextBlock
                    Text="{Binding Description}"
                    FontSize="11"
                    Foreground="{StaticResource MutedBrush}"
                    MaxLines="1"
                    TextTrimming="CharacterEllipsis"
                  />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock
                      Text="{Binding CreatedAt, Converter={StaticResource RelativeTimeConverter}}"
                      FontSize="10"
                      Foreground="{StaticResource HintBrush}"
                    />
                    <!-- Cache status for imported images -->
                    <Ellipse
                      Width="8"
                      Height="8"
                      VerticalAlignment="Center"
                      Fill="{Binding CacheBrush}"
                      Visibility="{Binding ShowCacheIndicator, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"
                    />
                    <TextBlock
                      Text="{Binding CacheLabel}"
                      FontSize="10"
                      Foreground="{StaticResource HintBrush}"
                      Visibility="{Binding ShowCacheIndicator, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"
                    />
                  </StackPanel>
                </StackPanel>

                <!-- Right: size and origin badge -->
                <StackPanel
                  Grid.Column="2"
                  VerticalAlignment="Center"
                  Margin="12,0"
                  Spacing="2"
                  HorizontalAlignment="Right"
                >
                  <TextBlock
                    FontSize="12"
                    Foreground="{StaticResource MutedBrush}"
                    HorizontalAlignment="Right"
                    Text="{Binding FileSizeBytes, Converter={StaticResource FileSizeConverter}}"
                  />
                  <Border
                    CornerRadius="3"
                    Padding="6,2"
                    HorizontalAlignment="Right"
                    Background="{Binding Origin, Converter={StaticResource OriginColorConverter}}"
                  >
                    <TextBlock
                      Text="{Binding Origin}"
                      FontSize="10"
                      Foreground="White"
                      FontWeight="SemiBold"
                    />
                  </Border>
                </StackPanel>

                <!-- Actions -->
                <StackPanel
                  Grid.Column="3"
                  Orientation="Horizontal"
                  Spacing="4"
                  VerticalAlignment="Center"
                >
                  <Button
                    Content="&#xE890;"
                    FontFamily="Segoe MDL2 Assets"
                    Click="PreviewBuildSteps_Click"
                    Tag="{Binding Id}"
                    ToolTipService.ToolTip="View Build Steps"
                    Visibility="{Binding IsBuilt, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"
                  />
                  <Button
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Publish"
                    Click="PublishImage_Click"
                    Tag="{Binding Id}"
                    Padding="10,4"
                    FontSize="12"
                  />
                  <Button
                    Content="Launch VM"
                    Click="LaunchVm_Click"
                    Tag="{Binding Id}"
                    Visibility="{Binding IsBuilt, Converter={StaticResource BoolToVisibilityConverter}}"
                    Padding="8,4"
                    FontSize="12"
                  />
                  <Button
                    Style="{StaticResource DangerButtonStyle}"
                    Content="{Binding DeleteButtonText}"
                    Click="DeleteImage_Click"
                    Tag="{Binding Id}"
                    IsEnabled="{Binding CanDelete}"
                  />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>
    </Grid>

    <!-- Feeds Management Panel (always visible) -->
    <Border
      Grid.Column="1"
      Background="{StaticResource SurfaceBrush}"
      BorderBrush="{StaticResource DividerBrush}"
      BorderThickness="1,0,0,0"
    >
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Feeds Header -->
        <Grid Grid.Row="0" Margin="16,16,16,8">
          <TextBlock
            Text="Feeds"
            FontSize="17"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextBrush}"
            VerticalAlignment="Center"
          />
        </Grid>

        <!-- Feed List -->
        <ListView Grid.Row="1" ItemsSource="{Binding Feeds}" SelectionMode="None" Margin="8,0,8,0">
          <ListView.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="12">
                <StackPanel Spacing="4">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon
                      Grid.Column="0"
                      Glyph="&#xE753;"
                      FontFamily="Segoe MDL2 Assets"
                      FontSize="16"
                      Foreground="{StaticResource AccentBrush}"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                    />
                    <TextBlock
                      Grid.Column="1"
                      Text="{Binding Name}"
                      FontSize="13"
                      FontWeight="SemiBold"
                      Foreground="{StaticResource TextBrush}"
                    />
                  </Grid>
                  <TextBlock
                    Text="{Binding SourceType}"
                    FontSize="10"
                    Foreground="{StaticResource HintBrush}"
                  />
                  <TextBlock
                    Text="{Binding ConnectionString}"
                    FontSize="10"
                    Foreground="{StaticResource MutedBrush}"
                    MaxLines="1"
                    TextTrimming="CharacterEllipsis"
                  />
                  <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                    <Button
                      Content="Edit"
                      FontSize="11"
                      Padding="8,4"
                      Click="EditFeed_Click"
                      Tag="{Binding Id}"
                    />
                    <Button
                      Content="Test"
                      FontSize="11"
                      Padding="8,4"
                      Click="TestFeed_Click"
                      Tag="{Binding Id}"
                    />
                    <Button
                      Style="{StaticResource DangerButtonStyle}"
                      Content="Delete"
                      FontSize="11"
                      Padding="8,4"
                      Click="DeleteFeed_Click"
                      Tag="{Binding Id}"
                    />
                  </StackPanel>
                  <TextBlock
                    x:Name="FeedTestStatusText"
                    FontSize="11"
                    Tag="{Binding Id}"
                    Visibility="Collapsed"
                  />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>

        <!-- Add Feed Button -->
        <Button
          Grid.Row="2"
          Style="{StaticResource FilledAccentButton}"
          Content="Add Feed"
          HorizontalAlignment="Stretch"
          Margin="16,8,16,16"
          Click="AddFeed_Click"
        />
      </Grid>
    </Border>
  </Grid>
</Page>
