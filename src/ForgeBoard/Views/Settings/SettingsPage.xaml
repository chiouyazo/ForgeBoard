<Page
  x:Class="ForgeBoard.Views.Settings.SettingsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="{StaticResource BgBrush}"
>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ScrollViewer Grid.Row="0" Padding="24">
      <StackPanel Spacing="24" MaxWidth="600" HorizontalAlignment="Stretch">
        <TextBlock
          Text="Settings"
          FontSize="24"
          FontWeight="Bold"
          Foreground="{StaticResource TextBrush}"
        />

        <Border Style="{StaticResource CardStyle}">
          <StackPanel Spacing="12">
            <TextBlock
              Text="Storage"
              FontSize="17"
              FontWeight="SemiBold"
              Foreground="{StaticResource TextBrush}"
            />
            <StackPanel Spacing="4">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock
                  Text="Max Cache Size:"
                  FontSize="13"
                  Foreground="{StaticResource MutedBrush}"
                />
                <TextBlock
                  Text="{Binding MaxCacheSizeGb}"
                  FontSize="13"
                  Foreground="{StaticResource MutedBrush}"
                />
                <TextBlock Text="GB" FontSize="13" Foreground="{StaticResource MutedBrush}" />
              </StackPanel>
              <Slider
                Minimum="10"
                Maximum="500"
                StepFrequency="10"
                Value="{Binding MaxCacheSizeGb, Mode=TwoWay}"
              />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}">
          <StackPanel Spacing="12">
            <TextBlock
              Text="Packer"
              FontSize="17"
              FontWeight="SemiBold"
              Foreground="{StaticResource TextBrush}"
            />
            <StackPanel Spacing="8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                  Grid.Column="0"
                  Header="Packer Path"
                  Text="{Binding PackerPath, Mode=TwoWay}"
                  PlaceholderText="Path to packer executable"
                  FontSize="13"
                  AcceptsReturn="False"
                  TextWrapping="NoWrap"
                  HorizontalAlignment="Stretch"
                  LostFocus="PackerPath_LostFocus"
                />
                <Button
                  Grid.Column="1"
                  Content="Browse"
                  Click="BrowsePackerPath_Click"
                  VerticalAlignment="Bottom"
                  Margin="8,0,0,0"
                  Visibility="{Binding IsLocalMode, Converter={StaticResource BoolToVisibilityConverter}}"
                />
              </Grid>
              <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock
                  Text="Version:"
                  FontSize="13"
                  Foreground="{StaticResource MutedBrush}"
                  VerticalAlignment="Center"
                />
                <TextBlock
                  Text="{Binding PackerVersion}"
                  FontSize="13"
                  Foreground="{Binding PackerVersionBrush}"
                  VerticalAlignment="Center"
                />
                <Button
                  Style="{StaticResource PrimaryButtonStyle}"
                  Content="Detect Packer"
                  Command="{Binding DetectPackerCommand}"
                />
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}">
          <StackPanel Spacing="12">
            <TextBlock
              Text="VM Credentials"
              FontSize="17"
              FontWeight="SemiBold"
              Foreground="{StaticResource TextBrush}"
            />
            <TextBlock
              Text="Username and password for WinRM connections to build VMs. Must match the credentials set in your Autounattend.xml."
              FontSize="12"
              TextWrapping="Wrap"
              Foreground="{StaticResource MutedBrush}"
            />
            <TextBox
              Header="Username"
              Text="{Binding WinrmUsername, Mode=TwoWay}"
              PlaceholderText="Administrator"
            />
            <PasswordBox
              Header="Password"
              Password="{Binding WinrmPassword, Mode=TwoWay}"
              PlaceholderText="Admin123!"
            />
            <TextBox
              Header="Hyper-V Switch"
              Text="{Binding HyperVSwitch, Mode=TwoWay}"
              PlaceholderText="Default Switch"
            />
            <TextBox
              Header="VmManager Agent URL"
              Text="{Binding VmManagerAgentUrl, Mode=TwoWay}"
              PlaceholderText="http://localhost:18275"
            />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}">
          <StackPanel Spacing="12">
            <TextBlock
              Text="General"
              FontSize="17"
              FontWeight="SemiBold"
              Foreground="{StaticResource TextBrush}"
            />
            <StackPanel Spacing="4">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock
                  Text="Max Concurrent Builds:"
                  FontSize="13"
                  Foreground="{StaticResource MutedBrush}"
                />
                <TextBlock
                  Text="{Binding MaxConcurrentBuilds}"
                  FontSize="13"
                  Foreground="{StaticResource MutedBrush}"
                />
              </StackPanel>
              <Slider
                Minimum="1"
                Maximum="8"
                StepFrequency="1"
                Value="{Binding MaxConcurrentBuilds, Mode=TwoWay}"
              />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}">
          <StackPanel Spacing="12">
            <TextBlock
              Text="Storage"
              FontSize="17"
              FontWeight="SemiBold"
              Foreground="{StaticResource TextBrush}"
            />
            <TextBlock
              Text="Paths used for the database, cache, artifacts, workspaces, logs, and temp files. Changes require an API restart."
              FontSize="12"
              TextWrapping="Wrap"
              Foreground="{StaticResource MutedBrush}"
            />

            <StackPanel Spacing="4">
              <TextBlock
                Text="Currently in use"
                FontSize="13"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextBrush}"
              />
              <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}">
                <Run Text="Data: " FontWeight="SemiBold" />
                <Run Text="{Binding CurrentDataDirectory}" />
              </TextBlock>
              <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}">
                <Run Text="Temp: " FontWeight="SemiBold" />
                <Run Text="{Binding CurrentTempDirectory}" />
              </TextBlock>
              <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}">
                <Run Text="Database: " FontWeight="SemiBold" />
                <Run Text="{Binding CurrentDatabasePath}" />
              </TextBlock>
            </StackPanel>

            <TextBox
              Header="Data directory (absolute path, leave empty for default)"
              Text="{Binding NewDataDirectory, Mode=TwoWay}"
              PlaceholderText="D:\ForgeBoard"
            />
            <TextBox
              Header="Temp directory (absolute path, leave empty to use {DataDirectory}\temp)"
              Text="{Binding NewTempDirectory, Mode=TwoWay}"
              PlaceholderText="D:\ForgeBoard\temp"
            />

            <Button
              Content="Save Storage Paths"
              Style="{StaticResource PrimaryButtonStyle}"
              Command="{Binding SaveStorageCommand}"
            />

            <Border
              Background="#33FFA500"
              CornerRadius="4"
              Padding="12,8"
              Visibility="{Binding StorageRestartRequired, Converter={StaticResource BoolToVisibilityConverter}}"
            >
              <StackPanel Spacing="8">
                <TextBlock
                  Text="Restart the API for the new paths to take effect."
                  FontSize="12"
                  Foreground="{StaticResource TextBrush}"
                  TextWrapping="Wrap"
                />
                <Button
                  Content="Restart API now"
                  HorizontalAlignment="Left"
                  Command="{Binding RestartApiCommand}"
                />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}">
          <StackPanel Spacing="8">
            <TextBlock
              Text="About"
              FontSize="17"
              FontWeight="SemiBold"
              Foreground="{StaticResource TextBrush}"
            />
            <TextBlock
              Text="{Binding ForgeBoardVersion}"
              FontSize="13"
              Foreground="{StaticResource MutedBrush}"
            />
            <TextBlock
              Text="Packer image build management"
              FontSize="11"
              Foreground="{StaticResource HintBrush}"
            />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border
      Grid.Row="1"
      Background="{StaticResource SurfaceBrush}"
      BorderBrush="{StaticResource DividerBrush}"
      BorderThickness="0,1,0,0"
      Padding="24,12"
    >
      <StackPanel Orientation="Horizontal" Spacing="16">
        <Button
          Style="{StaticResource FilledAccentButton}"
          Content="Save Settings"
          Command="{Binding SaveCommand}"
        />
        <TextBlock
          Text="{Binding ErrorMessage}"
          FontSize="13"
          Foreground="{StaticResource ErrorBrush}"
          VerticalAlignment="Center"
        />
        <TextBlock
          Text="{Binding SuccessMessage}"
          FontSize="13"
          Foreground="{StaticResource SuccessBrush}"
          VerticalAlignment="Center"
        />
        <TextBlock
          Text="{Binding SaveStatus}"
          FontSize="13"
          Foreground="{StaticResource SuccessBrush}"
          VerticalAlignment="Center"
        />
      </StackPanel>
    </Border>
  </Grid>
</Page>
