<Page
  x:Class="ForgeBoard.Views.Shell"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="{StaticResource BgBrush}"
>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="200" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border
      Grid.Column="0"
      Grid.RowSpan="2"
      Background="{StaticResource SurfaceBrush}"
      BorderBrush="{StaticResource DividerBrush}"
      BorderThickness="0,0,1,0"
    >
      <StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="10" Margin="16,20,16,24">
          <Image
            Source="ms-appx:///Assets/logo48.png"
            Width="32"
            Height="32"
            VerticalAlignment="Center"
          />
          <TextBlock
            Text="ForgeBoard"
            FontSize="20"
            FontWeight="Bold"
            Foreground="{StaticResource AccentBrush}"
            VerticalAlignment="Center"
          />
        </StackPanel>

        <Button
          x:Name="NavDashboard"
          Style="{StaticResource NavButtonActiveStyle}"
          Click="NavDashboard_Click"
        >
          <StackPanel Orientation="Horizontal" Spacing="10">
            <FontIcon Glyph="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            <TextBlock Text="Dashboard" />
          </StackPanel>
        </Button>

        <Button x:Name="NavBuilds" Style="{StaticResource NavButtonStyle}" Click="NavBuilds_Click">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <FontIcon Glyph="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            <TextBlock Text="Builds" />
          </StackPanel>
        </Button>

        <Button x:Name="NavImages" Style="{StaticResource NavButtonStyle}" Click="NavImages_Click">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <FontIcon Glyph="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            <TextBlock Text="Image Library" />
          </StackPanel>
        </Button>

        <Button x:Name="NavSteps" Style="{StaticResource NavButtonStyle}" Click="NavSteps_Click">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <FontIcon Glyph="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            <TextBlock Text="Step Library" />
          </StackPanel>
        </Button>

        <Button
          x:Name="NavSettings"
          Style="{StaticResource NavButtonStyle}"
          Click="NavSettings_Click"
        >
          <StackPanel Orientation="Horizontal" Spacing="10">
            <FontIcon Glyph="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
            <TextBlock Text="Settings" />
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <Grid Grid.Column="1" Grid.Row="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Global Notification Bar -->
      <Border x:Name="NotificationBar" Grid.Row="0" Padding="16,10" Visibility="Collapsed">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock
            x:Name="NotificationText"
            Grid.Column="0"
            FontSize="13"
            Foreground="White"
            VerticalAlignment="Center"
            TextWrapping="Wrap"
          />
          <Button
            Grid.Column="1"
            Content="&#xE711;"
            FontFamily="Segoe MDL2 Assets"
            Click="DismissNotification_Click"
            Foreground="White"
            Background="Transparent"
            BorderThickness="0"
            FontSize="10"
            Padding="8,4"
            VerticalAlignment="Center"
          />
        </Grid>
      </Border>

      <Frame x:Name="ContentFrame" Grid.Row="1" />
    </Grid>

    <Border
      Grid.Column="1"
      Grid.Row="1"
      Background="{StaticResource SurfaceBrush}"
      BorderBrush="{StaticResource DividerBrush}"
      BorderThickness="0,1,0,0"
      Padding="16,6"
    >
      <TextBlock
        x:Name="StatusText"
        Text="Ready"
        FontSize="11"
        Foreground="{StaticResource MutedBrush}"
      />
    </Border>
  </Grid>
</Page>
