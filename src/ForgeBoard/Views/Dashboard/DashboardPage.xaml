<Page
  x:Class="ForgeBoard.Views.Dashboard.DashboardPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="using:ForgeBoard.Controls"
  Background="{StaticResource BgBrush}"
>
  <ScrollViewer Padding="24">
    <StackPanel Spacing="24">
      <TextBlock
        Text="Dashboard"
        FontSize="24"
        FontWeight="Bold"
        Foreground="{StaticResource TextBrush}"
      />

      <TextBlock
        Text="Storage"
        FontSize="17"
        FontWeight="SemiBold"
        Foreground="{StaticResource TextBrush}"
        Margin="0,8,0,0"
      />

      <Border Style="{StaticResource CardStyle}">
        <controls:DiskUsageBar DiskUsage="{Binding DiskUsage}" />
      </Border>

      <!-- Active Publishes -->
      <TextBlock
        Text="Active Publishes"
        FontSize="17"
        FontWeight="SemiBold"
        Foreground="{StaticResource TextBrush}"
      />

      <ItemsRepeater ItemsSource="{Binding ActivePublishes}">
        <ItemsRepeater.Layout>
          <StackLayout Spacing="8" />
        </ItemsRepeater.Layout>
        <ItemsRepeater.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource CardStyle}">
              <StackPanel Spacing="6">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock
                    Grid.Column="0"
                    Text="{Binding DisplayText}"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextBrush}"
                    VerticalAlignment="Center"
                    TextWrapping="Wrap"
                  />
                  <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center"
                  >
                    <Button
                      Style="{StaticResource DangerButtonStyle}"
                      Content="Cancel"
                      FontSize="11"
                      Padding="10,4"
                      Click="CancelPublish_Click"
                      Tag="{Binding ArtifactId}"
                      Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                    />
                    <Button
                      Content="Dismiss"
                      FontSize="11"
                      Padding="10,4"
                      Click="DismissPublish_Click"
                      Tag="{Binding ArtifactId}"
                      Visibility="{Binding IsComplete, Converter={StaticResource BoolToVisibilityConverter}}"
                    />
                  </StackPanel>
                </Grid>
                <ProgressBar
                  Value="{Binding PercentComplete}"
                  Maximum="100"
                  Height="4"
                  Foreground="{StaticResource AccentBrush}"
                  Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsRepeater.ItemTemplate>
      </ItemsRepeater>

      <TextBlock
        Text="Active Builds"
        FontSize="17"
        FontWeight="SemiBold"
        Foreground="{StaticResource TextBrush}"
      />

      <ItemsRepeater x:Name="ActiveBuildsList" ItemsSource="{Binding ActiveBuilds}">
        <ItemsRepeater.Layout>
          <StackLayout Spacing="8" />
        </ItemsRepeater.Layout>
        <ItemsRepeater.ItemTemplate>
          <DataTemplate>
            <Button
              Style="{StaticResource ClickableCardButtonStyle}"
              Click="ActiveBuild_Click"
              Tag="{Binding ExecutionId}"
            >
              <Border Style="{StaticResource CardStyle}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock
                      Text="{Binding DisplayTitle}"
                      FontSize="13"
                      FontWeight="SemiBold"
                      Foreground="{StaticResource TextBrush}"
                    />
                    <controls:StatusBadge Status="{Binding Status}" />
                    <ProgressBar
                      IsIndeterminate="False"
                      Value="50"
                      Maximum="100"
                      Height="4"
                      Foreground="{StaticResource AccentBrush}"
                    />
                  </StackPanel>
                  <Button
                    Grid.Column="1"
                    Style="{StaticResource DangerButtonStyle}"
                    Content="Cancel"
                    Command="{Binding DataContext.CancelBuildCommand, ElementName=ActiveBuildsList}"
                    CommandParameter="{Binding ExecutionId}"
                    VerticalAlignment="Center"
                    Padding="12,4"
                  />
                </Grid>
              </Border>
            </Button>
          </DataTemplate>
        </ItemsRepeater.ItemTemplate>
      </ItemsRepeater>

      <TextBlock
        Text="No active builds"
        Visibility="{Binding ActiveBuilds.Count, Converter={StaticResource EmptyToVisibleConverter}, FallbackValue=Visible}"
        FontSize="13"
        Foreground="{StaticResource HintBrush}"
      />

      <TextBlock
        Text="No builds yet. Create your first build."
        Visibility="{Binding HasNoBuilds, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"
        FontSize="14"
        Foreground="{StaticResource MutedBrush}"
        Margin="0,8,0,0"
      />

      <TextBlock
        Text="Recent Builds"
        FontSize="17"
        FontWeight="SemiBold"
        Foreground="{StaticResource TextBrush}"
        Margin="0,8,0,0"
      />

      <TextBlock
        Text="No recent builds"
        Visibility="{Binding RecentBuilds.Count, Converter={StaticResource EmptyToVisibleConverter}, FallbackValue=Visible}"
        FontSize="13"
        Foreground="{StaticResource HintBrush}"
      />

      <ItemsRepeater ItemsSource="{Binding RecentBuilds}">
        <ItemsRepeater.Layout>
          <StackLayout Spacing="4" />
        </ItemsRepeater.Layout>
        <ItemsRepeater.ItemTemplate>
          <DataTemplate>
            <Button
              Style="{StaticResource ClickableCardButtonStyle}"
              Click="RecentBuild_Click"
              Tag="{Binding ExecutionId}"
            >
              <Border Style="{StaticResource CardStyle}" Padding="12">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <controls:StatusBadge
                    Grid.Column="0"
                    Status="{Binding Status}"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                  />
                  <TextBlock
                    Grid.Column="1"
                    Text="{Binding DisplayTitle}"
                    FontSize="13"
                    Foreground="{StaticResource TextBrush}"
                    VerticalAlignment="Center"
                  />
                  <TextBlock
                    Grid.Column="2"
                    Text="{Binding QueuedAt}"
                    FontSize="11"
                    Foreground="{StaticResource HintBrush}"
                    VerticalAlignment="Center"
                  />
                </Grid>
              </Border>
            </Button>
          </DataTemplate>
        </ItemsRepeater.ItemTemplate>
      </ItemsRepeater>
    </StackPanel>
  </ScrollViewer>
</Page>
