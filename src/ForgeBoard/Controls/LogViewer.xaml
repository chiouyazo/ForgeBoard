<UserControl
  x:Class="ForgeBoard.Controls.LogViewer"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBox
      x:Name="SearchBox"
      Grid.Row="0"
      PlaceholderText="Search logs..."
      TextChanged="SearchBox_TextChanged"
    />

    <TextBox
      x:Name="LogTextBox"
      Grid.Row="1"
      IsReadOnly="True"
      AcceptsReturn="True"
      TextWrapping="NoWrap"
      FontFamily="Consolas"
      FontSize="12"
      Background="White"
      Foreground="Black"
    />
  </Grid>
</UserControl>
